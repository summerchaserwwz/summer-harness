    { "id": "activation", "lane": "user", "col": 1, "type": "security", "label": "是否显式启用？", "sublabel": "复杂度只能建议", "tag": "Activation Gate" },
    { "id": "direct", "lane": "user", "col": 3, "type": "external", "label": "Direct 执行", "sublabel": "零 Summer 状态", "tag": "可按需用窄 Skill" },
